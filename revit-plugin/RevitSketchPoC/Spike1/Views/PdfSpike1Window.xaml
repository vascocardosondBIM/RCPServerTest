<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FFF1F5F9">

    <Grid.Resources>
        <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="Brush.Border" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="Brush.Text" Color="#FF0F172A" />
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#FF64748B" />
        <SolidColorBrush x:Key="Brush.Accent" Color="#FF2563EB" />
        <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF1D4ED8" />
        <SolidColorBrush x:Key="Brush.Status" Color="#FFB71C1C" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{StaticResource Brush.Accent}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="#FFF8FAFC"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFEFF6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Grid.Resources>

    <Grid Margin="20">
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="240" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Spike 1 - PDF Vetorial para JSON"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Text}" />
                    <TextBlock Text="Extrai geometria vetorial bruta (linhas, curvas, retângulos e texto) sem interpretação por IA."
                               FontSize="13"
                               Foreground="{StaticResource Brush.TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Height="40"
                             IsReadOnly="True"
                             Text="{Binding PdfPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,10,0"
                            Command="{Binding BrowsePdfCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📄" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Procurar PDF…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBox Grid.Column="2"
                             Height="40"
                             Text="{Binding PdfPageNumber, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <TextBox Grid.Row="2"
                         MinHeight="70"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Foreground="{StaticResource Brush.Status}"
                         Background="#FFFFFBFE"
                         BorderBrush="#FFFECACA"
                         Text="{Binding Status}" />

                <TextBox Grid.Row="3"
                         Margin="0,12,0,0"
                         MinHeight="220"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11"
                         Foreground="{StaticResource Brush.Text}"
                         Background="#FFF8FAFC"
                         Text="{Binding GeneratedJsonPreview}" />

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button Style="{StaticResource PrimaryButton}"
                            MinWidth="180"
                            Margin="0,0,10,0"
                            Command="{Binding GenerateJsonCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🧩" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Gerar JSON PDF" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            MinWidth="200"
                            Margin="0,0,10,0"
                            Command="{Binding OpenFolderCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📂" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Abrir pasta dos JSONs" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            MinWidth="150"
                            Command="{Binding SaveJsonCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="💾" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Guardar JSON…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Grid>
