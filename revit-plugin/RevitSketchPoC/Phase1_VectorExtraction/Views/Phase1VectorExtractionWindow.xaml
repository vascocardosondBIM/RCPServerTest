<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FFF1F5F9">

    <Grid.Resources>
        <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="Brush.Border" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="Brush.Text" Color="#FF0F172A" />
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#FF64748B" />
        <SolidColorBrush x:Key="Brush.Accent" Color="#FF2563EB" />
        <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF1D4ED8" />
        <SolidColorBrush x:Key="Brush.Status" Color="#FFB71C1C" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="Background" Value="#FFFFFFFF" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{StaticResource Brush.Accent}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="#FFF8FAFC"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFEFF6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Grid.Resources>

    <Grid Margin="20">
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="240" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Fase 1 — Extração PDF + zonas"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Text}" />
                    <TextBlock Text="Gera JSON modular e preview PNG. Depois define zonas (desenho, legendas, …) sobre o preview e exporta PNG + JSON filtrado por zona."
                               FontSize="13"
                               Foreground="{StaticResource Brush.TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Height="40" IsReadOnly="True"
                             Text="{Binding PdfPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Margin="10,0,10,0"
                            Command="{Binding BrowsePdfCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📄" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Procurar PDF…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBox Grid.Column="2" Height="40"
                             Text="{Binding PdfPageNumber, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,8" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Preset" />
                        <ComboBox Height="36" ItemsSource="{Binding QualityPresetOptions}"
                                  SelectedItem="{Binding SelectedQualityPreset, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Tile Size (pt)" />
                        <ComboBox Height="36" ItemsSource="{Binding TileSizeOptions}"
                                  SelectedItem="{Binding SelectedTileSizePt, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="AI Raster DPI" />
                        <ComboBox Height="36" ItemsSource="{Binding RasterDpiOptions}"
                                  SelectedItem="{Binding SelectedRasterDpi, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,8" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Calibração (pós-Fase 1)" />
                        <ComboBox Height="36" ItemsSource="{Binding CalibrationModeOptions}"
                                  SelectedItem="{Binding SelectedCalibrationMode, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Escala manual (1:N)" />
                        <TextBox Height="36" Text="{Binding ManualScaleDenominator, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4" Margin="0,0,0,8" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Height="34" Text="{Binding ReferenceP1XPt, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="2" Height="34" Text="{Binding ReferenceP1YPt, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="4" Height="34" Text="{Binding ReferenceP2XPt, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="6" Height="34" Text="{Binding ReferenceP2YPt, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="8" Height="34" Text="{Binding ReferenceDistanceMeters, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <ScrollViewer Grid.Row="5" MinHeight="56" MaxHeight="100"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,8">
                    <TextBox IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12"
                             Foreground="{StaticResource Brush.Status}" Background="#FFFFFBFE"
                             Text="{Binding Status}" />
                </ScrollViewer>

                <Grid Grid.Row="6" Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="160" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="Resumo da extração (contagens)" />
                    <Border Grid.Row="1" Background="#FFF8FAFC" BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1" CornerRadius="6" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <TextBlock Text="{Binding ExtractionSummary}" TextWrapping="Wrap"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource Brush.Text}" />
                        </ScrollViewer>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Style="{StaticResource PrimaryButton}" MinWidth="200" Margin="0,0,10,0"
                            Command="{Binding GenerateJsonCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🧩" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Gerar Fase 1" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" MinWidth="200" Margin="0,0,10,0"
                            Command="{Binding OpenRegionEditorCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="✂️" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Definir zonas…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" MinWidth="220" Margin="0,0,10,0"
                            Command="{Binding RunSemanticCommand}"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🧠" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Inferência semântica (LLM)" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" MinWidth="200" Margin="0,0,10,0"
                            Command="{Binding OpenFolderCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📂" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Abrir pasta output" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" MinWidth="220" Margin="0,0,10,0"
                            Command="{Binding ExportAllOutputsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Exportar todo o output…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" MinWidth="150" Command="{Binding SaveJsonCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="💾" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="Guardar raw…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Grid>
